# ============================================
#   NFT SNIPER BOT - CONFIGURATION
# ============================================

# Your wallet private key (NEVER share this!)
PRIVATE_KEY=your_private_key_here

# RPC Endpoint (Alchemy / Infura / QuickNode)
# Ethereum Mainnet example:
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# WebSocket RPC (for mempool monitoring - faster)
WS_RPC_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# NFT Contract address to snipe
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Mint function signature (default for most ERC721)
MINT_FUNCTION=mint(uint256)

# Number of NFTs to mint per transaction
MINT_AMOUNT=1

# Maximum price per NFT in ETH (0 = free mint)
MAX_PRICE_ETH=0.08

# Gas settings
GAS_LIMIT=300000
# Priority fee in Gwei (tip to miners - higher = faster)
MAX_PRIORITY_FEE_GWEI=50
# Max total gas fee in Gwei
MAX_FEE_GWEI=150

# Bot server port
PORT=3000

# Chain ID (1=Ethereum, 137=Polygon, 56=BSC, 42161=Arbitrum)
CHAIN_ID=1
